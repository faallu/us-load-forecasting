EIA_API_KEY=your-eia-api-key
EIA_BASE_URL=https://api.eia.gov/v2
# Day-boundary timezone for the EIA daily-region-sub-ba endpoint (used by 3mo/6mo/1yr
# windows). The endpoint returns the same sub-BA once per timezone; we keep just one.
EIA_DAILY_TIMEZONE=Eastern
DEFAULT_HISTORY_START=2023-01-01T00:00:00Z
PULL_BACKFILL_HOURS=24
INGEST_INTERVAL_MINUTES=60
TRAIN_INTERVAL_HOURS=24
FORECAST_HORIZON_HOURS=168

# Deployed pipeline is XGBoost-only.
FORECAST_MODEL=xgboost

# --- Storage backend -------------------------------------------------------
# "local" writes under ./data; "s3" writes under s3://$S3_BUCKET/$S3_PREFIX.
STORAGE_BACKEND=local
DATA_ROOT=data
S3_BUCKET=
S3_PREFIX=eia-load-forecasting
# AWS creds for s3 backend (omit on EC2/Lambda and use an IAM role instead).
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# --- XGBoost --------------------------------------------------------------
# Default hyperparameters (used when a window has no tuned best-params JSON).
# Per-window best params are discovered by the grid search and stored at
# s3://.../models/best_params/{window}.json (run: python -m src.jobs.run_train_and_forecast --tune-only).
XGB_N_ESTIMATORS=600
XGB_MAX_DEPTH=6
XGB_LEARNING_RATE=0.03
XGB_SUBSAMPLE=0.9
XGB_COLSAMPLE_BYTREE=0.9
XGB_MIN_CHILD_WEIGHT=1
# Fraction of each series held out as the test set for the XGBoost backtest
# (0.2 = 80% train / 20% test, chronological split using true lagged features).
XGB_TEST_FRACTION=0.2
