# Copy to airflow/.env and fill in. Consumed by docker-compose.yaml.

# Storage: use s3 in deployment. (local is only useful for a bind-mounted dev run.)
STORAGE_BACKEND=s3
S3_BUCKET=eia-load-forecasting
S3_PREFIX=

# AWS. On EC2 prefer an instance IAM role and leave the key/secret blank.
AWS_DEFAULT_REGION=us-east-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# EIA data source
EIA_API_KEY=your-eia-api-key
EIA_BASE_URL=https://api.eia.gov/v2
EIA_DAILY_TIMEZONE=Eastern
DEFAULT_HISTORY_START=2023-01-01T00:00:00Z

# XGBoost backtest split
XGB_TEST_FRACTION=0.2

# Airflow web admin (created by airflow-init)
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
